		<db:my-sql-connection host="${db.host}" port="${db.port}" user="${db.user}" password="${db.password}" database="${db.name}" />
	</db:config>
	<email:smtp-config name="SMTP_fakeSMTP_Config" doc:name="Email SMTP" doc:id="9ecabce9-6893-450a-a2c7-73a4c0352ffb" >
		<email:smtp-connection host="${smtp.host}" port="${smtp.port}"/>
	</email:smtp-config>
	<wsc:config name="WSC_EmpleadosSOAP_Config" doc:name="Web Service Consumer Config" doc:id="dc070bb0-6b2b-4175-9d4b-60787a9c1b99" >
		<wsc:connection wsdlLocation="C:\MTIS\workspaceEclipse\P1-Interoperabilidad\WSDL\Empleados.wsdl" service="Empleados" port="EmpleadosSOAP" address="http://localhost:8080/P1-Interoperabilidad/services/Empleados"/>
	</wsc:config>
	<wsc:config name="WSC_ControlPresenciaSOAP_Config" doc:name="Web Service Consumer Config" doc:id="f8baebd8-bb8b-4287-8423-58ce9c0841c6" >
		<wsc:connection wsdlLocation="C:\MTIS\workspaceEclipse\P1-Interoperabilidad\WSDL\ControlPresencia.wsdl" service="ControlPresencia" port="ControlPresenciaSOAP" address="http://localhost:8080/P1-Interoperabilidad/services/ControlPresencia" />
	</wsc:config>
