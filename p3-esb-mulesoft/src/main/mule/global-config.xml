http://www.mulesoft.org/schema/mule/jms http://www.mulesoft.org/schema/mule/jms/current/mule-jms.xsd">
	<configuration-properties doc:name="Configuration properties" doc:id="3dee9106-c8c4-4ddd-8e05-b22b6b7f3a68" file="app.properties" />
	<http:listener-config name="HTTP_Listener_9091_EmpleadosSOAP" doc:name="HTTP Listener config" doc:id="19e745e6-ccbb-4919-bf47-5d2804d4142f" >
		<http:listener-connection host="${http.host}" port="${http.port.soap.empleados}" />
	</http:listener-config>
	<http:listener-config name="HTTP_Listener_9092_NivelesREST" doc:name="HTTP Listener config" doc:id="253e1273-96ef-418a-ba7d-8f2e8bb26251" >
		<http:listener-connection host="${http.host}" port="${http.port.rest.niveles}" />
	</http:listener-config>
	<http:listener-config name="HTTP_Listener_9093_ProcesoNENV" doc:name="HTTP Listener config" doc:id="c29b4403-211e-42a4-bcfa-da7c27323a65" >
		<http:listener-connection host="${http.host}" port="${http.port.proceso.nenv}" />
	</http:listener-config>
	<http:listener-config name="HTTP_Listener_9094_ProcesoNUNVTS" doc:name="HTTP Listener config" doc:id="812bff0c-1bb8-4912-9370-e5e46704a505" >
		<http:listener-connection host="${http.host}" port="${http.port.proceso.nunvts}" />
