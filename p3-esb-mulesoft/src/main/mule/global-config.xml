		<http:request-connection protocol="${rest.p1.protocol}" host="${rest.p1.host}" port="${rest.p1.port}" />
	</http:request-config>
	<jms:config name="JMS_ActiveMQ_Config" doc:name="JMS Config" doc:id="a756fa36-8484-4643-a56f-b40bdc502fee" >
		<jms:active-mq-connection username="${jms.user}" password="${jms.password}">
			<jms:factory-configuration brokerUrl="${jms.broker.url}"/>
		</jms:active-mq-connection>
	</jms:config>
